{{ ansible_managed | comment }}

[client]
port = {{ mysql_port }}
socket = {{ mysql_socket }}

[mysqld]
port = {{ mysql_port }}
bind-address = {{ mysql_bind_address }}
datadir = {{ mysql_datadir }}
socket = {{ mysql_socket }}
pid-file = {{ mysql_pid_file }}
{% if mysql_skip_name_resolve %}
skip-name-resolve
{% endif %}
{% if mysql_sql_mode %}
sql_mode = {{ mysql_sql_mode }}
{% endif %}

# CIS hardening
skip-grant-tables = OFF
log-raw = OFF
local-infile = 0
skip-symbolic-links = YES

# validate_password: loaded as a COMPONENT in Percona/MySQL 8.0+
# (the old plugin-load = validate_password.so was removed in 8.0.26)
# Component is installed via SQL on first run — see secure-installation tasks.
# Policy is enforced via system variables below once the component is loaded.
validate_password.policy         = STRONG
validate_password.special_char_count = 1
validate_password.number_count   = 1
validate_password.mixed_case_count = 1
validate_password.length         = 14

# Logging configuration.
{% if mysql_log_error == 'syslog' or mysql_log == 'syslog' %}
syslog
syslog-tag = {{ mysql_syslog_tag }}
{% else %}
{% if mysql_log %}
log = {{ mysql_log }}
{% endif %}
log-error = {{ mysql_log_error }}
{% endif %}

{% if mysql_slow_query_log_enabled %}
# Slow query log configuration.
slow_query_log      = 1
slow_query_log_file = {{ mysql_slow_query_log_file }}
long_query_time     = {{ mysql_slow_query_time }}
{% endif %}

{% if inventory_hostname in groups['master'] | default([]) %}
# -------------------------------------------------------
# Replication - Primary (Master)
# -------------------------------------------------------
server-id       = {{ mysql_server_id }}
log_bin         = mysql-bin
log-bin-index   = mysql-bin.index
# expire_logs_days was removed in MySQL 8.0.26 — use seconds instead
binlog_expire_logs_seconds = {{ mysql_binlog_expire_logs_seconds }}
max_binlog_size            = {{ mysql_max_binlog_size }}
binlog_format              = {{ mysql_binlog_format }}
# master-info-repository = TABLE was removed in MySQL 8.0.23 — no longer needed,
# replica metadata is always written to InnoDB tables automatically.

{% for db in mysql_databases %}
{% if db.replicate | default(1) %}
binlog_do_db     = {{ db.name }}
{% else %}
binlog_ignore_db = {{ db.name }}
{% endif %}
{% endfor %}

{% elif inventory_hostname in groups['slave'] | default([]) %}
# -------------------------------------------------------
# Replication - Replica (Slave)
# -------------------------------------------------------
server-id        = {{ mysql_server_id }}
read_only        = ON
relay-log        = relay-bin
relay-log-index  = relay-bin.index
{% endif %}

# User is ignored when systemd manages the process.
user = mysql

# Memory settings.
key_buffer_size         = {{ mysql_key_buffer_size }}
max_allowed_packet      = {{ mysql_max_allowed_packet }}
table_open_cache        = {{ mysql_table_open_cache }}
sort_buffer_size        = {{ mysql_sort_buffer_size }}
read_buffer_size        = {{ mysql_read_buffer_size }}
read_rnd_buffer_size    = {{ mysql_read_rnd_buffer_size }}
myisam_sort_buffer_size = {{ mysql_myisam_sort_buffer_size }}
thread_cache_size       = {{ mysql_thread_cache_size }}
max_connections         = {{ mysql_max_connections }}
tmp_table_size          = {{ mysql_tmp_table_size }}
max_heap_table_size     = {{ mysql_max_heap_table_size }}
group_concat_max_len    = {{ mysql_group_concat_max_len }}
join_buffer_size        = {{ mysql_join_buffer_size }}

# query_cache_* removed entirely in MySQL 8.0 — not conditionally included.

# Other settings.
wait_timeout         = {{ mysql_wait_timeout }}
lower_case_table_names = {{ mysql_lower_case_table_names }}
event_scheduler      = {{ mysql_event_scheduler_state }}

# InnoDB settings.
# innodb_large_prefix and innodb_file_format were removed in MySQL 8.0 — not included.
innodb_file_per_table          = {{ mysql_innodb_file_per_table }}
innodb_buffer_pool_size        = {{ mysql_innodb_buffer_pool_size }}
innodb_log_file_size           = {{ mysql_innodb_log_file_size }}
innodb_log_buffer_size         = {{ mysql_innodb_log_buffer_size }}
innodb_flush_log_at_trx_commit = {{ mysql_innodb_flush_log_at_trx_commit }}
innodb_lock_wait_timeout       = {{ mysql_innodb_lock_wait_timeout }}

[mysqldump]
quick
max_allowed_packet = {{ mysql_mysqldump_max_allowed_packet }}

{% if mysql_config_include_files | length %}
# Additional config fragments — files must end with .cnf
!includedir {{ mysql_config_include_dir }}
{% endif %}
